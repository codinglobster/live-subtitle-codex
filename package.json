{
  "name": "iina-ai-subtitle-studio",
  "version": "0.0.1",
  "description": "IINA plugin for Groq Whisper subtitle generation",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist .parcel-cache && parcel build src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "iina-plugin-definition": "^0.99.0",
    "prettier": "^2.8.8"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.15",
    "parcel": "^2.8.3",
    "parcel-optimizer-webview": "git+https://github.com/iina/parcel-optimizer-webview.git"
  },
  "browserslist": "safari >= 13",
  "entry": "src/index.js",
  "targets": {
    "entry": {
      "distDir": "./dist/",
      "source": "src/index.js",
      "isLibrary": false
    }
  }
